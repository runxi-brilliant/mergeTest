# MongoDB
MONGODB_URI=mongodb://localhost:27017/campustrade

# JWT Secret - 把下面的值替换成你刚才生成的随机字符串
JWT_SECRET=PASTE_YOUR_RANDOM_STRING_HERE

# JWT 配置
JWT_ALGORITHM=HS256
ACCESS_TOKEN_EXPIRE_MINUTES=10080

# OpenAI API
OPENAI_API_KEY=

# Email Settings
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=

# App Settings
ALLOWED_EMAIL_DOMAINS=@university.edu,@student.ac.uk
UPLOAD_DIR=./uploads
MAX_UPLOAD_SIZE_MB=10
